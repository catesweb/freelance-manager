<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:notifications="using:Avalonia.Controls.Notifications">

  <!-- Custom NotificationCard styled to the app's design tokens:
       left accent bar + per-type icon, centered text, slimmer card.
       The PART_LayoutTransformControl wrapper and the entry / IsClosing
       animations are preserved verbatim from the Fluent default so the
       open/close motion is unchanged. -->
  <ControlTheme x:Key="{x:Type NotificationCard}" TargetType="NotificationCard">
    <Setter Property="UseLayoutRounding" Value="True"/>
    <Setter Property="Width" Value="300"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    <Setter Property="RenderTransformOrigin" Value="50%,75%"/>
    <Setter Property="Background" Value="{DynamicResource BgSurface}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
    <Setter Property="Template">
      <ControlTemplate>
        <LayoutTransformControl Name="PART_LayoutTransformControl" UseRenderTransform="True">
          <Border CornerRadius="{TemplateBinding CornerRadius}" BoxShadow="0 8 20 0 #28000000" Margin="5 5 5 10">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    ClipToBounds="True">
              <DockPanel>
                <Panel x:Name="PART_HeaderBar" Width="4" DockPanel.Dock="Left"
                       Background="{DynamicResource Info}"/>
                <Grid Margin="16,13" MinHeight="52">
                  <Path x:Name="PART_Icon" Width="18" Height="18" Stretch="Uniform"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Stroke="{DynamicResource Info}" StrokeThickness="1.6"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        Data="{StaticResource IconInfo}"/>
                  <ContentPresenter Name="PART_ContentPresenter" Margin="26,0"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                    Content="{TemplateBinding Content}">
                    <ContentPresenter.ContentTemplate>
                      <DataTemplate x:DataType="notifications:INotification">
                        <TextBlock Text="{Binding Message}" HorizontalAlignment="Stretch"
                                   TextAlignment="Center" TextWrapping="Wrap"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                      </DataTemplate>
                    </ContentPresenter.ContentTemplate>
                  </ContentPresenter>
                </Grid>
              </DockPanel>
            </Border>
          </Border>
        </LayoutTransformControl>
      </ControlTemplate>
    </Setter>

    <ControlTheme.Animations>
      <Animation Duration="0:0:0.45" Easing="QuadraticEaseIn" FillMode="Forward">
        <KeyFrame Cue="0%">
          <Setter Property="Opacity" Value="0"/>
          <Setter Property="TranslateTransform.Y" Value="20"/>
          <Setter Property="ScaleTransform.ScaleX" Value="0.85"/>
          <Setter Property="ScaleTransform.ScaleY" Value="0.85"/>
        </KeyFrame>
        <KeyFrame Cue="30%">
          <Setter Property="TranslateTransform.Y" Value="-20"/>
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="Opacity" Value="1"/>
          <Setter Property="TranslateTransform.Y" Value="0"/>
          <Setter Property="ScaleTransform.ScaleX" Value="1"/>
          <Setter Property="ScaleTransform.ScaleY" Value="1"/>
        </KeyFrame>
      </Animation>
    </ControlTheme.Animations>

    <Style Selector="^[IsClosing=true] /template/ LayoutTransformControl#PART_LayoutTransformControl">
      <Setter Property="RenderTransformOrigin" Value="50%,0%"/>
      <Style.Animations>
        <Animation Duration="0:0:0.75" Easing="QuadraticEaseOut" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="TranslateTransform.X" Value="0"/>
            <Setter Property="ScaleTransform.ScaleY" Value="1"/>
          </KeyFrame>
          <KeyFrame Cue="70%">
            <Setter Property="TranslateTransform.X" Value="800"/>
            <Setter Property="ScaleTransform.ScaleY" Value="1"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="ScaleTransform.ScaleY" Value="0"/>
            <Setter Property="TranslateTransform.X" Value="800"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="^[IsClosing=true]">
      <Style.Animations>
        <Animation Duration="0:0:1.25" Easing="QuadraticEaseOut" FillMode="Forward">
          <KeyFrame Cue="100%">
            <Setter Property="IsClosed" Value="True"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Per-type accent bar + icon, using the app's semantic tokens -->
    <Style Selector="^:information /template/ Panel#PART_HeaderBar">
      <Setter Property="Background" Value="{DynamicResource Info}"/>
    </Style>
    <Style Selector="^:information /template/ Path#PART_Icon">
      <Setter Property="Stroke" Value="{DynamicResource Info}"/>
      <Setter Property="Data" Value="{StaticResource IconInfo}"/>
    </Style>

    <Style Selector="^:success /template/ Panel#PART_HeaderBar">
      <Setter Property="Background" Value="{DynamicResource Success}"/>
    </Style>
    <Style Selector="^:success /template/ Path#PART_Icon">
      <Setter Property="Stroke" Value="{DynamicResource Success}"/>
      <Setter Property="Data" Value="{StaticResource IconCheckCircle}"/>
    </Style>

    <Style Selector="^:warning /template/ Panel#PART_HeaderBar">
      <Setter Property="Background" Value="{DynamicResource Warning}"/>
    </Style>
    <Style Selector="^:warning /template/ Path#PART_Icon">
      <Setter Property="Stroke" Value="{DynamicResource Warning}"/>
      <Setter Property="Data" Value="{StaticResource IconAlertCircle}"/>
    </Style>

    <Style Selector="^:error /template/ Panel#PART_HeaderBar">
      <Setter Property="Background" Value="{DynamicResource Danger}"/>
    </Style>
    <Style Selector="^:error /template/ Path#PART_Icon">
      <Setter Property="Stroke" Value="{DynamicResource Danger}"/>
      <Setter Property="Data" Value="{StaticResource IconAlertCircle}"/>
    </Style>
  </ControlTheme>
</ResourceDictionary>
