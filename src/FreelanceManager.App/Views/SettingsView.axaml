<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FreelanceManager.App.ViewModels"
             xmlns:c="using:FreelanceManager.App.Controls"
             x:Class="FreelanceManager.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Left">
      <c:PageHeader Title="Settings">
        <c:PageHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="secondary" Content="Backup now" Command="{Binding BackupNowCommand}"/>
            <Button Classes="primary" Content="Save" Command="{Binding SaveCommand}"/>
          </StackPanel>
        </c:PageHeader.Actions>
      </c:PageHeader>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="SectionHeading" Text="Business profile"/>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Business name"/>
            <TextBox Text="{Binding Name}"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Address"/>
            <TextBox Text="{Binding Address}" AcceptsReturn="True" Height="60"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Email"/>
            <TextBox Text="{Binding Email}"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Phone"/>
            <TextBox Text="{Binding Phone}"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Logo path"/>
            <TextBox Text="{Binding LogoPath}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="SectionHeading" Text="Invoicing defaults"/>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Default currency"/>
            <TextBox Text="{Binding DefaultCurrency}"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Default tax rate (e.g. 0.2)"/>
            <TextBox Text="{Binding DefaultTaxRate}"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Invoice number format"/>
            <TextBox Text="{Binding InvoiceNumberFormat}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="SectionHeading" Text="Email (SMTP)"/>
          <TextBlock Classes="Caption" Text="Used to send invoices by email. Password is encrypted at rest."/>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="SMTP host"/>
            <TextBox Text="{Binding SmtpHost}" PlaceholderText="smtp.gmail.com"/>
          </StackPanel>
          <Grid ColumnDefinitions="*,Auto" >
            <StackPanel Grid.Column="0" Margin="0,0,12,0" Spacing="4">
              <TextBlock Classes="FieldLabel" Text="Port"/>
              <TextBox Text="{Binding SmtpPort}" Width="100" HorizontalAlignment="Left"/>
            </StackPanel>
            <CheckBox Grid.Column="1" VerticalAlignment="Bottom" Content="Use SSL/TLS" IsChecked="{Binding SmtpUseSsl}"/>
          </Grid>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Username"/>
            <TextBox Text="{Binding SmtpUsername}"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Password"/>
            <TextBox Text="{Binding SmtpPassword}" PasswordChar="•" PlaceholderText="Leave blank to keep current"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="From email (defaults to business email)"/>
            <TextBox Text="{Binding SmtpFromEmail}"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="From name (defaults to business name)"/>
            <TextBox Text="{Binding SmtpFromName}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="SectionHeading" Text="Appearance"/>
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Theme"/>
            <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Theme}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="SectionHeading" Text="Updates"/>
          <TextBlock Classes="FieldLabel" Text="{Binding AppVersion, StringFormat='Current version: {0}'}"/>
          <Button Classes="secondary" Content="Check for updates" Command="{Binding CheckForUpdatesCommand}"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
