<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FreelanceManager.App.ViewModels"
             xmlns:c="using:FreelanceManager.App.Controls"
             x:Class="FreelanceManager.App.Views.InvoiceEditView"
             x:DataType="vm:InvoicesViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" MaxWidth="820" HorizontalAlignment="Left">
      <c:PageHeader Title="Edit invoice">
        <c:PageHeader.Actions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="primary" Content="Save invoice" Command="{Binding SaveCommand}"/>
            <Button Classes="secondary" Content="Cancel" Command="{Binding CancelCommand}"/>
          </StackPanel>
        </c:PageHeader.Actions>
      </c:PageHeader>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <StackPanel Spacing="4">
            <TextBlock Classes="FieldLabel" Text="Client *"/>
            <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding ClientOptions}" SelectedItem="{Binding EditorClient}">
              <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
          <StackPanel Spacing="10" DataContext="{Binding Editor}" x:CompileBindings="False">
            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Margin="0,0,12,0" Spacing="4">
                <TextBlock Classes="FieldLabel" Text="Number"/>
                <TextBox Text="{Binding Number}"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Classes="FieldLabel" Text="Status"/>
                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}"/>
              </StackPanel>
            </Grid>
            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Margin="0,0,12,0" Spacing="4">
                <TextBlock Classes="FieldLabel" Text="Issue date"/>
                <DatePicker SelectedDate="{Binding IssueDate}"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Classes="FieldLabel" Text="Due date"/>
                <DatePicker SelectedDate="{Binding DueDate}"/>
              </StackPanel>
            </Grid>
            <StackPanel Spacing="4">
              <TextBlock Classes="FieldLabel" Text="Tax rate (e.g. 0.2)"/>
              <TextBox Text="{Binding TaxRate}"/>
            </StackPanel>

            <TextBlock Classes="SectionHeading" Text="Line items" Margin="0,6,0,0"/>
            <DataGrid ItemsSource="{Binding Lines}" AutoGenerateColumns="False" Height="200" CanUserReorderColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}"/>
                <DataGridTextColumn Header="Unit" Binding="{Binding UnitPrice}"/>
                <DataGridTextColumn Header="Total" Binding="{Binding LineTotal, StringFormat={}{0:0.00}}" IsReadOnly="True"/>
              </DataGrid.Columns>
            </DataGrid>
            <Button Classes="secondary" Content="Add line" Command="{Binding AddLineCommand}" HorizontalAlignment="Left"/>

            <StackPanel Spacing="2" HorizontalAlignment="Right">
              <TextBlock Classes="Caption" Text="{Binding Subtotal, StringFormat=Subtotal: {0:0.00}}"/>
              <TextBlock Classes="Caption" Text="{Binding Tax, StringFormat=Tax: {0:0.00}}"/>
              <TextBlock Classes="SectionHeading" Text="{Binding Total, StringFormat=Total: {0:0.00}}"/>
            </StackPanel>

            <StackPanel Spacing="4">
              <TextBlock Classes="FieldLabel" Text="Notes"/>
              <TextBox Text="{Binding Notes}" AcceptsReturn="True" Height="60"/>
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
